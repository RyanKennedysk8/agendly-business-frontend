{
  "expo": {
    "name": "AgendlyBusiness",
    "slug": "AgendlyBusiness",
    "scheme": "agendlybusiness",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo3d.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.majorkennedy.AgendlyBusiness"
    },
    "android": {
      "bundleIdentifier": "com.majorkennedy.AgendlyBusiness",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/images/logo3d.png",
        "backgroundImage": "./src/assets/images/logo3d.png",
        "monochromeImage": "./src/assets/images/logo3d.png"
      },
      "package": "com.majorkennedy.AgendlyBusiness"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/logo3d.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/logo3d.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "088bb634-f409-4a7b-9cc9-ede3883a731c"
      }
    },
    "owner": "majorkennedy"
  }
}
